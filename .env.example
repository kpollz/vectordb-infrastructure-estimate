# =============================================================================
# RAG Infrastructure Benchmark — biến môi trường mẫu
# =============================================================================
# Cách dùng:
#   cp .env.example .env      # rồi sửa .env theo máy của bạn
#   python run_benchmark.py   # tự nạp .env (không cần --flag)
#
# THỨ TỰ ƯU TIÊN (cao → thấp):
#   1. Cờ CLI            (vd: --docs 50000)   ← luôn thắng
#   2. Biến môi trường   (BENCH_* dưới đây)
#   3. Default trong code
#
# Biến shell thật LUÔN thắng .env (load_dotenv không ghi đè biến đã tồn tại).
# Đổi đường dẫn file env:  BENCH_ENV_FILE=prod.env python run_benchmark.py
# =============================================================================

# ---- Kết nối Qdrant ----------------------------------------------------------
# URL tới Qdrant server (đã bật qua docker/docker-compose.bench.yml).
BENCH_QDRANT_URL=http://localhost:6333
# Tên collection benchmark (sẽ bị recreate mỗi lần chạy — đừng trỏ vào prod!).
BENCH_COLLECTION=bench_chunks

# ---- Thiết bị tính toán ------------------------------------------------------
# cpu | cuda. CHỈ áp dụng cho embedding + rerank. Qdrant search & sparse encode
# LUÔN chạy CPU/server bất kể giá trị này (khớp docker-compose.gpu.yml của prod:
# chỉ api/worker được cấp GPU, Qdrant là container CPU riêng).
BENCH_DEVICE=cpu

# ---- Model (mặc định = production chat-with-documents) -----------------------
# Override để so sánh kiến trúc khác (vd đa ngữ: BAAI/bge-m3,
# intfloat/multilingual-e5-large). Để trống = dùng đúng model production.
BENCH_EMBED_MODEL=sentence-transformers/all-MiniLM-L12-v2
BENCH_RERANK_MODEL=BAAI/bge-reranker-v2-m3

# ---- Quy mô corpus & workload ------------------------------------------------
# Số chunk khi KHÔNG bật scale-test.
BENCH_DOCS=10000
# Số token/chunk (= CHUNK_MAX_TOKENS của prod). Token đếm theo whitespace split.
BENCH_CHUNK_TOKENS=512
# Số query đo tuần tự / kích thước pool query.
BENCH_QUERIES=200
# Batch encode khi ingest (giảm nếu OOM VRAM; GTX 1650 Ti 4GB nên thử 32-64).
BENCH_BATCH_SIZE=256

# ---- Tải song song (đo QPS thật) ---------------------------------------------
# Danh sách mức concurrency, cách nhau bởi dấu phẩy hoặc khoảng trắng.
BENCH_CONCURRENCY=1,4,8,16

# ---- Retrieval (khớp app/config.py của prod) ---------------------------------
# HYBRID_CANDIDATES: số ứng viên mỗi modality trước fusion/rerank.
BENCH_CANDIDATES=20
# RETRIEVAL_TOP_K: số kết quả cuối sau rerank.
BENCH_TOP_K=5

# ---- HNSW (ảnh hưởng RAM & recall của Qdrant) --------------------------------
BENCH_HNSW_M=16
BENCH_HNSW_EF_CONSTRUCT=100

# ---- Quantization (đòn bẩy giảm RAM vector) ----------------------------------
# none | scalar (INT8, ~4x nhỏ hơn) | binary (~32x nhỏ hơn, giảm recall).
BENCH_QUANTIZATION=none

# ---- Scale test --------------------------------------------------------------
# true = chạy qua nhiều mốc BENCH_SCALE_POINTS để phân tích xu hướng.
BENCH_SCALE_TEST=false
BENCH_SCALE_POINTS=1000,5000,10000,50000,100000

# ---- Đầu ra ------------------------------------------------------------------
BENCH_OUTPUT=benchmark_results.json
BENCH_SEED=42

# =============================================================================
# Biến hệ thống (KHÔNG phải BENCH_*) — do thư viện HuggingFace/PyTorch đọc
# =============================================================================
# Thư mục cache model HuggingFace (mặc định ~/.cache/huggingface). Đặt lên ổ
# nhiều dung lượng nếu tải nhiều model lớn (bge-reranker-v2-m3 ~2.2GB).
# HF_HOME=/media/gnust/500mb/hf_cache

# Chạy offline hoàn toàn (không ping HF Hub) SAU khi model đã cache — tránh
# lỗi mạng lúc benchmark. Bật cả hai:
# HF_HUB_OFFLINE=1
# TRANSFORMERS_OFFLINE=1

# Chọn GPU cụ thể trên máy nhiều card (index bắt đầu từ 0).
# CUDA_VISIBLE_DEVICES=0

# Số luồng CPU cho torch khi BENCH_DEVICE=cpu (mặc định = số core). Giảm để đo
# công bằng khi so với 1 container bị bó core.
# OMP_NUM_THREADS=8
